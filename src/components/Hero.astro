---
import type { YearStats } from '../lib/movies';

interface Props {
  year: number;
  stats: YearStats;
}

const { year, stats } = Astro.props;

const avgLabel = stats.avg.toFixed(1);
---

<div class="container mx-auto px-4 pt-10 pb-6 text-center sm:pt-14">
  <p
    lang="en"
    class="mb-3 inline-flex items-center gap-2 text-xs font-medium uppercase tracking-[0.25em] text-indigo-300/80"
  >
    <span class="h-px w-6 bg-indigo-400/40"></span>
    Cinema Log
    <span class="h-px w-6 bg-indigo-400/40"></span>
  </p>

  <h1
    class="text-3xl font-bold tracking-tight drop-shadow-[0_2px_20px_rgba(99,102,241,0.25)] sm:text-4xl md:text-5xl"
  >
    <span aria-hidden="true">🎬</span>
    <span
      class="bg-gradient-to-b from-white via-slate-100 to-slate-400 bg-clip-text text-transparent"
      >Jiakai 的观影记录</span
    >
  </h1>

  <p class="mx-auto mt-3 max-w-md text-sm text-slate-400 sm:text-base">
    记录每一部看过的电影与剧集
  </p>

  {
    stats.count > 0 && (
      <dl class="mx-auto mt-7 flex max-w-md flex-wrap items-stretch justify-center gap-3 text-left">
        <div class="flex min-w-[7.5rem] flex-1 flex-col rounded-2xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur">
          <dt class="text-[11px] uppercase tracking-wider text-slate-400">{year} 年观影</dt>
          <dd class="mt-0.5 text-2xl font-semibold tabular-nums text-white">
            {stats.count}
            <span class="ml-0.5 text-sm font-normal text-slate-400">部</span>
          </dd>
        </div>
        <div class="flex min-w-[7.5rem] flex-1 flex-col rounded-2xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur">
          <dt class="text-[11px] uppercase tracking-wider text-slate-400">平均评分</dt>
          <dd class="mt-0.5 flex items-baseline gap-1">
            <span class="text-2xl font-semibold tabular-nums text-white">{avgLabel}</span>
            <span class="text-lg text-amber-400" aria-hidden="true">★</span>
          </dd>
        </div>
      </dl>
    )
  }
</div>
