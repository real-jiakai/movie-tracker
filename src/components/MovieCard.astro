---
import type { MovieVM } from '../lib/movies';

type Props = MovieVM;

const { title, dateLabel, sortKey, rating, review, poster, url, type } = Astro.props;

const fullStars = Math.round(rating);
const ratingLabel = rating.toFixed(1);
const typeLabel = type === 'tv' ? '剧集' : '电影';
---

<li
  data-card
  data-title={title.toLowerCase()}
  data-rating={rating}
  data-date={sortKey}
  class="h-full"
>
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="group block h-full rounded-2xl focus:outline-hidden focus-visible:ring-4 focus-visible:ring-indigo-400/80"
  >
    <article
    class="flex h-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] shadow-lg shadow-black/20 transition-all duration-300 group-hover:-translate-y-1 group-hover:border-indigo-400/40 group-hover:shadow-glow group-focus-visible:border-indigo-400/60 group-focus-visible:shadow-glow"
  >
    <div class="relative aspect-[2/3] overflow-hidden bg-ink-700">
      <div class="skeleton absolute inset-0" aria-hidden="true"></div>
      <img
        src={poster}
        alt={`《${title}》海报`}
        width="400"
        height="600"
        loading="lazy"
        decoding="async"
        class="poster absolute inset-0 z-10 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.06]"
      />

      {/* rating chip */}
      <span
        class="absolute right-2 top-2 z-20 inline-flex items-center gap-0.5 rounded-full bg-black/55 px-2 py-0.5 text-xs font-semibold tabular-nums text-amber-300 ring-1 ring-white/10 backdrop-blur"
      >
        <span aria-hidden="true">★</span>{ratingLabel}
      </span>

      {/* type tag */}
      <span
        class="absolute left-2 top-2 z-20 rounded-full bg-black/45 px-2 py-0.5 text-[10px] font-medium tracking-wide text-slate-200 ring-1 ring-white/10 backdrop-blur"
      >
        {typeLabel}
      </span>

      {/* bottom scrim + stars */}
      <div
        class="absolute inset-x-0 bottom-0 z-20 bg-gradient-to-t from-black/85 via-black/30 to-transparent px-3 pb-2.5 pt-8"
      >
        <div class="text-sm leading-none tracking-tight" aria-hidden="true">
          <span class="text-amber-400">{'★'.repeat(fullStars)}</span><span
            class="text-slate-600">{'★'.repeat(5 - fullStars)}</span>
        </div>
      </div>
    </div>

    <div class="flex flex-1 flex-col p-3.5">
      <h2
        class="line-clamp-2 text-base font-semibold leading-snug text-slate-100 transition-colors group-hover:text-indigo-300"
      >
        {title}
      </h2>
      <p class="mt-1 text-xs text-slate-400">{dateLabel}</p>
      {
        review && (
          <p class="mt-2 line-clamp-3 whitespace-pre-line text-sm leading-relaxed text-slate-400">
            {review}
          </p>
        )
      }
    </div>
  </article>
  </a>
</li>
