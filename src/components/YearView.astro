---
import Layout from '../layouts/Layout.astro';
import Navigation from './Navigation.astro';
import Toolbar from './Toolbar.astro';
import MovieGrid from './MovieGrid.astro';
import { moviesForYear, statsForYear, type MovieEntry } from '../lib/movies';

interface Props {
  year: number;
  years: number[];
  counts: Record<number, number>;
  all: MovieEntry[];
  isHomepage?: boolean;
}

const { year, years, counts, all, isHomepage = false } = Astro.props;
const movies = moviesForYear(all, year);
const stats = statsForYear(movies);

// The homepage mirrors the newest year, so both URLs canonicalize to "/".
const canonicalPath = isHomepage || year === years[0] ? '/' : `/${year}/`;
const description =
  stats.count > 0
    ? `${year} 年 Jiakai 看过的 ${stats.count} 部电影与剧集，平均评分 ${stats.avg.toFixed(1)} 星。`
    : `Jiakai 在 ${year} 年的观影记录。`;
---

<Layout
  title={`${year} 年度观影 · Jiakai`}
  year={year}
  stats={stats}
  description={description}
  canonicalPath={canonicalPath}
  ogImage={movies[0]?.poster}
>
  <Navigation years={years} currentYear={year} movieCounts={counts} slot="navigation" />
  {
    movies.length > 0 ? (
      <>
        <Toolbar total={movies.length} />
        <MovieGrid movies={movies} />
      </>
    ) : (
      <div class="container mx-auto px-4 py-20 text-center text-sm text-slate-400">
        暂无公开观影记录。
      </div>
    )
  }
</Layout>
