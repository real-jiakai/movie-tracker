---
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#070b14" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>页面不存在 · Jiakai 的观影记录</title>
  </head>
  <body
    class="flex min-h-screen flex-col items-center justify-center bg-ink-900 px-4 text-center text-slate-100 antialiased"
  >
    <p class="text-6xl" aria-hidden="true">🎬</p>
    <h1 class="mt-6 text-2xl font-bold">页面不存在</h1>
    <p class="mt-2 text-sm text-slate-400">你要找的页面可能已被移动或删除。</p>
    <a
      href="/"
      class="mt-6 rounded-full bg-indigo-500 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-400 focus-visible:ring-4 focus-visible:ring-indigo-400/60"
      >返回首页</a
    >
  </body>
</html>
