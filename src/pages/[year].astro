---
import YearView from '../components/YearView.astro';
import { getViewingData } from '../lib/movies';

export async function getStaticPaths() {
  const { years } = await getViewingData();
  return years.map((year) => ({ params: { year: String(year) } }));
}

const currentYear = Number(Astro.params.year);
const { all, years, counts } = await getViewingData();
---

<YearView year={currentYear} years={years} counts={counts} all={all} />
